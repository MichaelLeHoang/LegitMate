{
  "name": "@legitmate/web-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/package-extension.mjs --if-missing",
    "dev": "vite",
    "prebuild": "node scripts/package-extension.mjs",
    "build": "tsc --noEmit && vite build",
    "package:extension": "node scripts/package-extension.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
