# Web dashboard configuration (Vite).
# Copy to `.env` and adjust. Only VITE_-prefixed vars are exposed to the bundle.
# `.env` is gitignored; this `.env.example` is the committed template.

# App version shown in the hero "New v…" tag (e.g. 2.0 renders "New v2.0").
VITE_APP_VERSION="2.0"

# Public GitHub repository URL (navbar + hero "GitHub" buttons).
VITE_GITHUB_URL="https://github.com/MichaelLeHoang/LegitMate"

# Chrome Web Store listing for the extension.
# Leave empty until published — while empty, "Add to Chrome" opens the install
# modal (download .zip + load unpacked). Once set, it opens the store listing.
VITE_CHROME_STORE_URL=""

# Pre-store phase: where "Add to Chrome" downloads the packaged extension from.
# Empty -> /legitmate-extension.zip served from the site (run
# `make package-extension` to generate it). Can point at a GitHub release asset.
VITE_EXTENSION_DOWNLOAD_URL=""

# Optional footer legal links. Leave empty to render them as plain text.
VITE_PRIVACY_URL=""
VITE_TERMS_URL=""
